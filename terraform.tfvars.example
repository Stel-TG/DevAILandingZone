###############################################################################
# TERRAFORM VARIABLE VALUES - EXAMPLE
# Copy this file to terraform.tfvars and populate with your actual values.
# terraform.tfvars is listed in .gitignore to prevent secret exposure.
###############################################################################

# Core identity
project_name  = "aiplatform"
environment   = "prod"
location      = "canadacentral"
location_short = "cc"
cost_center   = "CC-12345"
owner_email   = "platform-team@contoso.com"

# Subscriptions (replace with actual IDs)
spoke_subscription_id = "00000000-0000-0000-0000-000000000000"
hub_subscription_id   = "11111111-1111-1111-1111-111111111111"
tenant_id             = "22222222-2222-2222-2222-222222222222"

# Module feature flags - set to false to skip
deploy_policy               = true
deploy_log_analytics        = true
deploy_monitor              = true
deploy_application_insights = true
deploy_networking           = true
deploy_key_vault            = true
deploy_storage              = true
deploy_container_registry   = true
deploy_machine_learning     = true
deploy_cognitive_services   = false  # Enable when AI Services needed
deploy_openai               = false  # Enable when OpenAI access approved
deploy_private_endpoints    = true
deploy_rbac                 = true

# Networking
hub_vnet_id        = "/subscriptions/11111111-1111-1111-1111-111111111111/resourceGroups/rg-hub-network/providers/Microsoft.Network/virtualNetworks/vnet-hub-prod"
hub_vnet_name      = "vnet-hub-prod"
hub_resource_group = "rg-hub-network"

# Spoke VNET: 10.226.214.192/26 (64 IPs: .192–.255)
# Subnets (four /28 blocks, 16 IPs each) — defaults match variable definitions:
#   machine-learning   10.226.214.192/28   (.192–.207)
#   private-endpoints  10.226.214.208/28   (.208–.223)
#   databricks-public  10.226.214.224/28   (.224–.239)
#   databricks-private 10.226.214.240/28   (.240–.255)
# Override only if you need non-default subnet assignments:
# vnet_address_space = ["10.226.214.192/26"]

# Monitoring
alert_email_addresses = ["platform-alerts@contoso.com", "oncall@contoso.com"]

# RBAC - replace with actual AAD group object IDs
data_scientist_group_id   = "33333333-3333-3333-3333-333333333333"
ml_engineer_group_id      = "44444444-4444-4444-4444-444444444444"
data_engineer_group_id    = "55555555-5555-5555-5555-555555555555"
ai_app_developer_group_id = "66666666-6666-6666-6666-666666666666"
platform_admin_group_id   = "77777777-7777-7777-7777-777777777777"

# OpenAI (only if deploy_openai = true)
openai_location = "eastus"
openai_model_deployments = {
  "gpt-4-turbo" = {
    model_name    = "gpt-4"
    model_version = "turbo-2024-04-09"
    capacity      = 10
  }
  "text-embedding-3-large" = {
    model_name    = "text-embedding-3-large"
    model_version = "1"
    capacity      = 30
  }
}
